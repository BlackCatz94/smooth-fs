# ============================================================================
# SmoothFS frontend — example env
#
# Copy to `.env` (gitignored) for local dev. For Railway / production, set
# these as service variables so they're compiled into the Vite bundle at
# build time (Vite inlines VITE_* vars; changing them in prod requires a
# fresh deploy).
# ============================================================================

VITE_API_BASE_URL=http://localhost:3000

# Opt-in "this is a public demo" banner. Set to `true` on the deployed
# leave unset (or `false`) locally.
VITE_DEMO_MODE=false
