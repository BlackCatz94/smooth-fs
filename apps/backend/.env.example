# ============================================================================
# SmoothFS backend — example env
#
# Copy this file to `.env` (already gitignored) and REPLACE every `CHANGE_ME`
# before deploying beyond localhost. The values below are safe dev defaults for
# the containers started by `docker compose up -d`, NOT production credentials.
# ============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Local dev credentials for the postgres container in docker-compose.yml.
# For any non-local environment: replace user, password, host, and db with
# real values and NEVER commit them.
DATABASE_URL=postgres://CHANGE_ME:CHANGE_ME@localhost:5432/smoothfs
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=5000
DB_SLOW_QUERY_MS=200
HTTP_SLOW_REQUEST_MS=500

# Local dev Redis from docker-compose.yml. In staging/prod use rediss:// with
# an auth string (e.g. redis://:CHANGE_ME@redis.internal:6379).
REDIS_URL=redis://127.0.0.1:6379

MAX_TREE_DEPTH=64

ENABLE_CLEANUP_WORKER=false
CLEANUP_RETENTION_DAYS=30
CLEANUP_BATCH_SIZE=500
CLEANUP_CRON=0 3 * * *

# Phase 3 Redis cache (hot read paths). Off by default; uses a separate logical
# Redis DB from the BullMQ queue (which sits on DB 0 by default).
ENABLE_CACHE=false
CACHE_REDIS_DB=1
CACHE_TTL_MS=60000

# Phase 4 Frontend integration
FRONTEND_ORIGIN=http://localhost:5173

# ----------------------------------------------------------------------------
# Production / Railway reference values (DO NOT commit real secrets)
# ----------------------------------------------------------------------------
# On Railway, Postgres + Redis addons inject DATABASE_URL and REDIS_URL
# automatically. Additionally set on the backend service:
#   NODE_ENV=production
#   ENABLE_CACHE=true
#   ENABLE_CLEANUP_WORKER=true
#   LOG_LEVEL=info
#
# With a custom domain (recommended, see DEPLOYMENT.md → Custom domain):
#   FRONTEND_ORIGIN=https://smoothfs.cloud
#
# Without a custom domain, reference the frontend service directly so the
# value self-updates when Railway rotates the subdomain:
#   FRONTEND_ORIGIN=https://${{ frontend.RAILWAY_PUBLIC_DOMAIN }}
