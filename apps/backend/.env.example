NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5432/smoothfs
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=5000
DB_SLOW_QUERY_MS=200
HTTP_SLOW_REQUEST_MS=500

REDIS_URL=redis://127.0.0.1:6379

MAX_TREE_DEPTH=64

ENABLE_CLEANUP_WORKER=false
CLEANUP_RETENTION_DAYS=30
CLEANUP_BATCH_SIZE=500
CLEANUP_CRON=0 3 * * *

# Phase 3 Redis cache (hot read paths). Off by default; uses a separate logical
# Redis DB from the BullMQ queue (which sits on DB 0 by default).
ENABLE_CACHE=false
CACHE_REDIS_DB=1
CACHE_TTL_MS=60000
