{
  "name": "@smoothfs/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config ../../eslint.config.js .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/adapters/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/adapters/db/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@smoothfs/shared": "workspace:*",
    "bullmq": "^5.37.0",
    "drizzle-orm": "^0.38.4",
    "elysia": "^1.2.12",
    "ioredis": "^5.5.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.2",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.9.3"
  }
}
